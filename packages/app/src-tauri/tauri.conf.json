{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MythicIQ",
  "version": "0.1.0",
  "identifier": "app.mythiciq.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @wow/app dev:desktop",
    "devUrl": "http://localhost:5175",
    "beforeBuildCommand": "pnpm --filter @wow/app build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MythicIQ",
        "width": 1440,
        "height": 920,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#0e1116"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
