# Copy to .env.local to point the app at the backend (mechanics + discovery + run-stats + run backups).
# When unset, the app runs fully offline: it uses the build-time mechanics bundle and skips all backend
# sync (discovery, run-stats, and cloud run backups). The CI frontend build sets these from the
# app-stack CloudFormation outputs.
VITE_BACKEND_URL=http://localhost:8787

# Cognito sign-in (accounts + cloud run backups). Both must be set for the sign-in UI to appear; when
# unset, the app has no sign-in and cloud backup is disabled (everything else still works offline).
# Values come from the app stack outputs: HostedUiDomain and UserPoolClientId.
VITE_COGNITO_DOMAIN=https://wow-mplus-<accountId>.auth.<region>.amazoncognito.com
VITE_COGNITO_CLIENT_ID=<UserPoolClientId>
# Optional — defaults to the app origin + "/" (must match a Cognito app-client callback URL).
# VITE_COGNITO_REDIRECT_URI=http://localhost:5173/

# LFG near-instant match push (WebSocket). The app-stack output LfgWsUrl (wss://…/prod). When unset, the
# Groups feature falls back to the poll-on-open inbox (a match still shows next time you open Groups).
# VITE_LFG_WS_URL=wss://<wsApiId>.execute-api.<region>.amazonaws.com/prod

# --- DESKTOP (Tauri) build only ---------------------------------------------------------------------
# The desktop app uses its OWN Cognito app client (long-lived refresh token + a fixed loopback callback;
# sign-in opens the system browser and captures the redirect on http://localhost:8765/). For a desktop
# build (`desktop:dev` / `desktop:build`) set, in addition to VITE_BACKEND_URL + VITE_COGNITO_DOMAIN:
#   VITE_COGNITO_CLIENT_ID=<UserPoolClientDesktopId>   # the DESKTOP app-client output, not the web one
# The redirect URI is forced to the loopback on desktop, so VITE_COGNITO_REDIRECT_URI is ignored there.
# Accounts AND Groups/LFG are enabled automatically on desktop (no VITE_FEATURE_ACCOUNTS / VITE_FEATURE_GROUPS
# needed). For the Groups feature, the desktop build still needs VITE_BACKEND_URL (+ Cognito above) and,
# for the near-instant match push, VITE_LFG_WS_URL (else Groups falls back to the poll-on-open inbox).
# Armory character lookup needs no client env — it's served by the backend (gated on its Blizzard creds).
# Public web origin that serves shared replays at /r/<code>. On desktop, share links must point at the
# deployed web app (not the Tauri origin), so set this for desktop builds. Defaults to the prod domain.
# VITE_PUBLIC_BASE_URL=https://mythiciq.app
